{
  "name": "agentic-sage",
  "version": "1.0.0",
  "type": "module",
  "description": "Passive fleet judge for parallel AI coding agent sessions (Claude Code, Grok Build CLI, etc.) — board, territory checks, merge briefings.",
  "bin": {
    "sage": "./bin/sage",
    "agentic-sage": "./bin/sage"
  },
  "files": [
    "bin",
    "lib",
    "hooks",
    "skills",
    "adapters",
    "templates",
    "uninstall",
    "install.mjs",
    "scripts",
    "AGENTS.md",
    "SETUP.md",
    "ADAPTERS.md",
    "CONVENTIONS.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "node --test",
    "postinstall": "node scripts/postinstall.mjs",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "author": "Mateusz Muślewski <10kento10@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muslewski/agentic-sage.git"
  },
  "bugs": {
    "url": "https://github.com/muslewski/agentic-sage/issues"
  },
  "homepage": "https://sage.muslewski.com/",
  "keywords": [
    "claude-code",
    "grok",
    "grok-build",
    "agents",
    "fleet",
    "tmux",
    "git-worktree",
    "sessions",
    "orchestration",
    "multi-agent"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.5.3"
  }
}
