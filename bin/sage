#!/usr/bin/env node
// The `sage` CLI — a read-mostly fleet-judge front-end over P1's records.
// Resolves the repo from cwd; degrades to a clear line on any non-git/empty case.
import os from 'node:os'
import fs from 'node:fs'
import path from 'node:path'
import { fileURLToPath } from 'node:url'
import { resolveRepoId, resolveRepoRoot } from '../lib/repo-id.mjs'
import { loadAdapter, zoneOf, rowOf } from '../lib/adapter.mjs'
import { collectSessions, renderBoard, spinnerize } from '../lib/board.mjs'
import { SPINNER_FRAMES, SPINNER_INTERVAL_MS } from '../lib/spinner.mjs'
import {
  setEnabled,
  linkSession,
  unlinkSession,
  listRepos,
  doctor,
  renderDoctor,
} from '../lib/control.mjs'
import {
  territory,
  whyDiverged,
  mergeBrief,
  renderTerritory,
  renderWhyDiverged,
  renderMergeBrief,
} from '../lib/territory.mjs'
import { crossStat } from '../lib/git.mjs'
import { fleetLine } from '../lib/fleet.mjs'
import { tmuxPanes, paneForPid } from '../lib/tmux.mjs'
import { readStdinWithDeadline } from '../lib/stdin.mjs'
import {
  readGuard,
  addGuardPath,
  rmGuardPath,
  setGuardEnabled,
  renderGuard,
  relForRepo,
} from '../lib/guard.mjs'
import { resolveSelfSid } from '../lib/self.mjs'
import { mergeRecord, readRecord, readJson } from '../lib/store.mjs'
import { isEnabled } from '../lib/enabled.mjs'
import { globalConfig } from '../lib/paths.mjs'
import { markAsking, askingAgeMs, clearAsking } from '../lib/asking.mjs'
import { backlogStatus, renderBacklog } from '../lib/backlog.mjs'
import { paint } from '../lib/color.mjs'

// Colorize all string output at the single print chokepoint. paint() is a
// no-op when piped / NO_COLOR, so captured output (tests, pipes) stays plain.
const _log = console.log.bind(console)
console.log = (...args) => _log(...args.map((a) => (typeof a === 'string' ? paint(a) : a)))

const USAGE = `usage: sage <command>
  board [--watch]      roster of this repo's sessions (--watch = live)
  fleet                one-line nearest-neighbour summary
  territory <glob…>    who else claims/touches these paths (pre-flight)
  why-diverged <file>  which sessions touch a file + why (+ numstat)
  merge-brief          all contested paths before you merge
  repos                list all judged repos
  on | off             enable/disable SAGE globally
  link <sid> [state]   manual link_state override (default: linked)
  unlink <sid>         mark a session unlinked (closed)
  claim <glob…>        register this session's intent (claimed_globs)
  backlog              rows × live sessions: who holds what, orphans, .md drift
  backlog claim <row>  register THIS session's backlog row (claimed_row)
  guard …              list | add <path> | rm <path> | on | off (default OFF)
  adapter init         scaffold .sage/adapter.mjs from the template
  init                 wire skills + hooks into ~/.claude (run after npm install)
  doctor               validate dirs / hook / settings / token-forecast
  statusline           the "Asking Sage" status-bar segment (empty unless consulting)`

// Load the optional per-repo adapter + its ctx (project enrichment; null on any
// repo with no adapter → the agnostic P1–P4 path).
const adapterCtx = async (home, repoId, cwd) => {
  const ctx = { repoRoot: resolveRepoRoot(cwd) }
  return { ctx, adapter: await loadAdapter(home, repoId, ctx.repoRoot) }
}

// Live board: alt-screen + hidden cursor, repaint every frame (re-collecting
// sessions so liveness/ctx/age refresh live), Ctrl-C restores and exits. `build`
// renders the board for a given spinner frame. TTY-only (the caller guards).
const runWatch = (build) => {
  const W = process.stdout
  let i = 0
  W.write('\x1b[?1049h\x1b[?25l') // enter alt screen, hide cursor
  const draw = () => {
    W.write('\x1b[H\x1b[2J' + paint(build(SPINNER_FRAMES[i % SPINNER_FRAMES.length])) + '\n')
    i++
  }
  draw()
  const t = setInterval(draw, SPINNER_INTERVAL_MS)
  const stop = () => {
    clearInterval(t)
    W.write('\x1b[?25h\x1b[?1049l') // show cursor, leave alt screen
    process.exit(0)
  }
  process.on('SIGINT', stop)
}

const main = async () => {
  const [cmd, a1, a2] = process.argv.slice(2)
  const home = os.homedir()
  const cwd = process.cwd()
  const now = Date.now()

  // Best-effort: stamp this session's "asking" breadcrumb so a statusline can
  // surface it. Only marks a session SAGE is enabled for AND already has a
  // record for — a read verb never fabricates a record.
  const stampAsking = (repoId, verb) => {
    try {
      if (!repoId || !isEnabled({ home, repoId, cwd })) return
      const sid = resolveSelfSid(home, repoId)
      if (sid && !/[/\\]|\.\./.test(sid) && readRecord(home, repoId, sid)) markAsking(home, sid, verb)
    } catch {
      /* best-effort — never let the breadcrumb break a consult */
    }
  }

  switch (cmd) {
    case 'board': {
      const repoId = resolveRepoId(cwd)
      if (!repoId) return console.log('sage: not a git repo (cd into a repo SAGE judges)')
      const flags = process.argv.slice(3)
      const watch = flags.includes('--watch')
      const wide = flags.includes('--wide') || flags.includes('-w')
      const { ctx, adapter } = await adapterCtx(home, repoId, cwd)
      // build(frame): re-collect + render. frame == null → static (no spinner).
      const build = (frame) => {
        const sessions = collectSessions(home, repoId, Date.now())
        if (adapter) for (const s of sessions) { const r = rowOf(adapter, ctx, s); if (r) s.row = r.row }
        const panes = tmuxPanes() // best-effort: jumpable pane per live session
        if (panes.length) for (const s of sessions) { if (s.pid) s.tmux = paneForPid(s.pid, panes) }
        const text = renderBoard(sessions, { repoId, wide })
        return frame == null ? text : spinnerize(text, sessions, frame)
      }
      // --watch animates, but only on a real TTY; piped/non-TTY → one static frame.
      if (!watch || !process.stdout.isTTY) return console.log(build(null))
      return runWatch(build)
    }
    case 'fleet': {
      const repoId = resolveRepoId(cwd)
      if (!repoId) return console.log('sage: not a git repo')
      stampAsking(repoId, 'fleet')
      const selfSid = resolveSelfSid(home, repoId) || undefined
      const line = fleetLine(collectSessions(home, repoId, now), { selfSid })
      return console.log(line ? `sage: ${line}` : 'sage: no other sessions')
    }
    case 'territory': {
      const repoId = resolveRepoId(cwd)
      if (!repoId) return console.log('sage: not a git repo (cd into a repo SAGE judges)')
      stampAsking(repoId, 'territory')
      const queries = process.argv.slice(3)
      if (!queries.length) return console.log('usage: sage territory <glob> [glob…]')
      const selfSid = resolveSelfSid(home, repoId) || undefined
      const overlaps = territory(home, repoId, queries, { now, selfSid })
      const { ctx, adapter } = await adapterCtx(home, repoId, cwd)
      if (adapter) for (const o of overlaps) o.zone = zoneOf(adapter, ctx, o.hit)
      return console.log(renderTerritory(overlaps, { queries }))
    }
    case 'why-diverged': {
      const repoId = resolveRepoId(cwd)
      if (!repoId) return console.log('sage: not a git repo')
      stampAsking(repoId, 'why-diverged')
      if (!a1) return console.log('usage: sage why-diverged <file>')
      const selfSid = resolveSelfSid(home, repoId) || undefined
      const touches = whyDiverged(home, repoId, a1, { now, selfSid })
      // Tier 2 (on demand): real cross-branch numstat for each session that has a
      // live worktree, compared against the first other contesting branch.
      for (const t of touches) {
        const other = touches.find((o) => o.branch && o.branch !== t.branch)
        if (t.worktree && t.branch && other) t.stat = crossStat(t.worktree, other.branch, t.branch, a1)
      }
      const { ctx, adapter } = await adapterCtx(home, repoId, cwd)
      if (adapter) for (const t of touches) t.zone = zoneOf(adapter, ctx, a1)
      return console.log(renderWhyDiverged(touches, { file: a1 }))
    }
    case 'merge-brief': {
      const repoId = resolveRepoId(cwd)
      if (!repoId) return console.log('sage: not a git repo')
      stampAsking(repoId, 'merge-brief')
      const selfSid = resolveSelfSid(home, repoId) || undefined
      const { ctx, adapter } = await adapterCtx(home, repoId, cwd)
      const extraGlobs = adapter?.generatedGlobs?.() ?? []
      const contested = mergeBrief(home, repoId, { now, selfSid, extraGlobs })
      if (adapter) for (const c of contested) c.zone = zoneOf(adapter, ctx, c.path)
      return console.log(renderMergeBrief(contested, { repoId }))
    }
    case 'repos': {
      const repos = listRepos(home)
      if (!repos.length) return console.log('sage: no judged repos yet')
      return console.log(repos.map((r) => `  ${r.repoId}  (${r.sessions} session(s))`).join('\n'))
    }
    case 'on':
    case 'off':
      setEnabled(home, cmd === 'on')
      return console.log(`SAGE globally ${cmd === 'on' ? 'enabled' : 'disabled'}`)
    case 'link':
    case 'unlink': {
      const repoId = resolveRepoId(cwd)
      if (!repoId) return console.log('sage: not a git repo')
      if (!a1) return console.log(`usage: sage ${cmd} <session_id>${cmd === 'link' ? ' [state]' : ''}`)
      cmd === 'link'
        ? linkSession(home, repoId, a1, a2 || 'linked')
        : unlinkSession(home, repoId, a1)
      return console.log(`sage: ${cmd === 'link' ? `linked ${a1} (${a2 || 'linked'})` : `unlinked ${a1}`}`)
    }
    case 'claim': {
      const repoId = resolveRepoId(cwd)
      if (!repoId) return console.log('sage: not a git repo')
      const globs = process.argv.slice(3)
      if (!globs.length) return console.log('usage: sage claim <glob> [glob…]')
      const sid = resolveSelfSid(home, repoId)
      if (!sid)
        return console.log(
          'sage: cannot resolve the current session — run inside an enabled session, or set SAGE_SELF_SID',
        )
      if (/[/\\]|\.\./.test(sid)) return console.log('sage: refusing an unsafe SAGE_SELF_SID')
      if (!readRecord(home, repoId, sid))
        return console.log(`sage: no open record for ${sid} here — claim from the session that owns it`)
      mergeRecord(home, repoId, sid, {
        claimed_globs: globs,
        link_state: 'linked',
        updated_at: new Date(now).toISOString(),
      })
      try {
        markAsking(home, sid, 'claim') // best-effort breadcrumb — never break the claim
      } catch {
        /* ignore */
      }
      return console.log(`sage: claimed ${globs.join(' ')} on ${sid}`)
    }
    case 'backlog': {
      const repoId = resolveRepoId(cwd)
      if (!repoId) return console.log('sage: not a git repo (cd into a repo SAGE judges)')
      if (a1 === 'claim') {
        const row = (a2 || '').trim()
        // Strict id shape — the SAME shape backlogRows recognizes (letter+digits);
        // rejects spaces, control chars, and any punctuation noise (a guard, since
        // the value is stored + rendered). A1·R-style sub-rows aren't coordinated.
        if (!/^[A-Za-z]\d{1,6}$/.test(row))
          return console.log('usage: sage backlog claim <row>   (e.g. D11)')
        const sid = resolveSelfSid(home, repoId)
        if (!sid)
          return console.log(
            'sage: cannot resolve the current session — run inside an enabled session, or set SAGE_SELF_SID',
          )
        if (/[/\\]|\.\./.test(sid)) return console.log('sage: refusing an unsafe SAGE_SELF_SID')
        if (!readRecord(home, repoId, sid))
          return console.log(`sage: no open record for ${sid} here — claim from the session that owns it`)
        mergeRecord(home, repoId, sid, {
          claimed_row: row,
          link_state: 'linked',
          updated_at: new Date(now).toISOString(),
        })
        try {
          markAsking(home, sid, 'backlog-claim') // best-effort breadcrumb
        } catch {
          /* ignore */
        }
        return console.log(`sage: claimed row ${row} on ${sid}`)
      }
      // read-only board
      stampAsking(repoId, 'backlog')
      const { ctx, adapter } = await adapterCtx(home, repoId, cwd)
      if (!adapter || typeof adapter.backlogRows !== 'function')
        return console.log('sage: no backlog adapter for this repo')
      let rows = []
      try {
        rows = adapter.backlogRows(ctx) || []
      } catch {
        rows = [] // fail-closed-to-empty: a throwing adapter never crashes the CLI
      }
      if (!rows.length) return console.log('sage: no backlog rows found')
      const sessions = collectSessions(home, repoId, now)
      const panes = tmuxPanes()
      for (const s of sessions) {
        if (panes.length && s.pid) s.tmux = paneForPid(s.pid, panes)
        s.resolvedRow = s.claimed_row || rowOf(adapter, ctx, s)?.row || null
      }
      return console.log(renderBacklog(backlogStatus(rows, sessions, now), { repoId }))
    }
    case 'guard': {
      const repoId = resolveRepoId(cwd)
      if (!repoId) return console.log('sage: not a git repo')
      const sub = a1 || 'list'
      if (sub === 'add' || sub === 'rm') {
        if (!a2) return console.log(`usage: sage guard ${sub} <path>`)
        // Normalize to repo-relative (from the git toplevel) so an absolute, a
        // ./-prefixed, or a from-subdirectory path matches the emitter's
        // repo-relative target — otherwise it silently guards nothing.
        const root = resolveRepoRoot(cwd) || cwd
        let p = relForRepo(path.resolve(cwd, a2), root)
        // A bare existing directory guards nothing without /** — expand it.
        if (sub === 'add' && !/[*?]/.test(p)) {
          try {
            if (fs.statSync(path.resolve(cwd, a2)).isDirectory()) p = `${p.replace(/\/$/, '')}/**`
          } catch {
            /* not an existing dir — keep as a literal path */
          }
        }
        sub === 'add' ? addGuardPath(home, repoId, p) : rmGuardPath(home, repoId, p)
        return console.log(`sage: guard ${sub === 'add' ? 'added' : 'removed'} ${p}`)
      }
      if (sub === 'on') {
        setGuardEnabled(home, repoId, true)
        return console.log('sage: guard ARMED — SAGE will now block edits to contested paths here')
      }
      if (sub === 'off') {
        setGuardEnabled(home, repoId, false)
        return console.log('sage: guard disarmed')
      }
      return console.log(renderGuard(readGuard(home, repoId)))
    }
    case 'statusline': {
      // Fail-open: NEVER break the status bar. Resolve session+cwd from flags →
      // stdin JSON (the Claude statusline payload) → env. Print the configured
      // label only while a consult is fresh AND SAGE is on; otherwise nothing.
      try {
        const slArgs = process.argv.slice(3)
        const flag = (n) => {
          const i = slArgs.indexOf(n)
          return i >= 0 ? slArgs[i + 1] : undefined
        }
        let sid = flag('--session')
        let scwd = flag('--cwd')
        if ((!sid || !scwd) && !process.stdin.isTTY) {
          try {
            const p = JSON.parse(await readStdinWithDeadline(300))
            sid = sid || p.session_id
            scwd = scwd || p.cwd
          } catch {
            /* no / garbage stdin — fall through */
          }
        }
        sid = sid || process.env.CLAUDE_SESSION_ID
        scwd = scwd || cwd
        if (!sid) return
        const repoId = resolveRepoId(scwd)
        if (!isEnabled({ home, repoId, cwd: scwd })) return
        const cfg = readJson(globalConfig(home)) || {}
        const ttlMs = Number.isFinite(cfg.statuslineTtlMs) ? cfg.statuslineTtlMs : 8000
        const label = typeof cfg.statuslineLabel === 'string' ? cfg.statuslineLabel : '⚖️ Asking Sage'
        if (askingAgeMs(home, sid, now) < ttlMs) process.stdout.write(label)
        else clearAsking(home, sid)
      } catch {
        /* fail-open: print nothing */
      }
      return
    }
    case 'adapter': {
      const root = resolveRepoRoot(cwd)
      if (!root) return console.log('sage: not a git repo (cd into the repo you want an adapter for)')
      if ((a1 || 'init') !== 'init')
        return console.log('usage: sage adapter init   (scaffold .sage/adapter.mjs from the template)')
      const dest = path.join(root, '.sage', 'adapter.mjs')
      const rel = path.relative(root, dest)
      if (fs.existsSync(dest)) return console.log(`sage: ${rel} already exists — edit it (won't overwrite)`)
      const tmpl = path.join(path.dirname(fileURLToPath(import.meta.url)), '..', 'adapters', 'template.mjs')
      fs.mkdirSync(path.dirname(dest), { recursive: true })
      fs.copyFileSync(tmpl, dest)
      return console.log(
        `sage: scaffolded ${rel} from the template\n` +
          `  → edit it to teach SAGE your repo's vocabulary (see ADAPTERS.md)\n` +
          `  → it's committable; or symlink it out-of-tree to ~/.claude/sage/repos/<id>/adapter.mjs`,
      )
    }
    case 'init': {
      const { wireAll, formatResult } = await import('../lib/wiring.mjs')
      const repoRoot = path.join(path.dirname(fileURLToPath(import.meta.url)), '..')
      let result
      try {
        result = wireAll({ home, repoRoot })
      } catch (e) {
        console.error(e.message)
        process.exit(1)
      }
      return console.log(formatResult(result))
    }
    case 'doctor':
      return console.log(renderDoctor(doctor(home, cwd)))
    default:
      return console.log(USAGE)
  }
}

main().catch((e) => console.log(`sage: ${e && e.message ? e.message : 'error'}`))
