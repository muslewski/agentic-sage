// Colorize all string output at the single print chokepoint. paint() is a
// no-op when piped / NO_COLOR, so captured output (tests, pipes) stays plain.
const _log = console.log.bind(console)
console.log = (...args) => _log(...args.map((a) => (typeof a === 'string' ? paint(a) : a)))

const USAGE = `usage: sage <command>   (for Claude Code, Grok Build CLI, and other AI agents)
  board [--watch] [--wide|-w] [--all] [--json]  live-first roster; --all expands archive
  war [--json] [--wide|-w] [--all]       live cross-repo fleet cockpit; ? help · X clear dead
  fleet [--json]                         one-line nearest-neighbour summary
  territory <glob…>    who else claims/touches these paths (pre-flight)
  why-diverged <file>  which sessions touch a file + why (+ numstat)
  merge-brief          all contested paths before you merge
  repos [--all]        product/orphan atlas; --all expands orphan fold
  prune [--days N] [--yes]   remove closed/dead sessions older than N days (default 7)
  on | off             enable/disable SAGE globally
  link <sid> [state]   manual link_state override (default: linked)
  unlink <sid>         mark a session unlinked (closed)
  claim <glob…>        register this session's intent (claimed_globs)
  backlog              rows × live sessions: who holds what, orphans, .md drift
  backlog claim <row>  register THIS session's backlog row (claimed_row)
  guard …              list | add <path> | rm <path> | on | off (default OFF)
  adapter init         scaffold .agentic-sage/adapter.mjs from the template
  init                 wizard (TTY) or --global|--project|--repair|--show — wire skills+hooks
  where                this repo's resolved scope, storage dir, and matched rule
  enable | disable     per-repo enable override (independent of global on/off)
  doctor               validate dirs / hook / settings / token-forecast
  statusline           the "Asking Sage" status-bar segment (empty unless consulting)
  judge on --fleet|--repo [--takeover]  register THIS session as live judge
  judge off            clear judge role; stale own brief
  judge status         live judges + brief ages
  judge show [--fleet|--repo]  print fresh brief text
  judge publish        stdin JSON → atomic brief write (skill loop)
  judge run [--auto|--fleet|--repo] [--harness auto|grok|claude|none]
            [--once] [--takeover] [--print-only]  start live judge (easy path)`

// Load the optional per-repo adapter + its ctx (project enrichment; null on any
// repo with no adapter → the agnostic P1–P4 path).
const adapterCtx = async (home, repoId, cwd) => {
  const ctx = { repoRoot: resolveRepoRoot(cwd) }
  return { ctx, adapter: await loadAdapter(home, repoId, ctx.repoRoot) }
}

// Optional fzf over product repos → jump to hottest live session (board-style
// cd/tmux hint). Cancel / missing fzf → false (caller prints plain atlas).
const tryReposFzfJump = (home, view, { all = false, now = Date.now() } = {}) => {
  const rows = [...(view.product || []), ...(all ? view.orphan || [] : [])]
  if (!rows.length) return false
  if (!process.stdout.isTTY || !process.stdin.isTTY) return false
  let fzfPath
  try {
    fzfPath = execFileSync('sh', ['-c', 'command -v fzf'], { encoding: 'utf8' }).trim()
  } catch {
    return false
  }
  if (!fzfPath) return false
  const input = rows.map(fzfRepoLine).join('\n')
  let stdout = ''
  try {
    stdout = execFileSync(
      fzfPath,
      ['--height=40%', '--reverse', '--prompt=repos ❯ ', '--delimiter=\t', '--with-nth=1'],
      {
        encoding: 'utf8',
        input,
        stdio: ['pipe', 'pipe', 'inherit'],
      },
    )
  } catch {
    return false
  }
  const line = String(stdout || '').trim()
  if (!line) return false
  const repoId = line.includes('\t') ? line.split('\t').pop() : ''
  const hit = rows.find((r) => r.repoId === repoId) || rows.find((r) => line.includes(r.repoId))
  if (!hit) return false
  // Hottest live session in that repo → board-style jump; else print board hint.
  let sessions = []
  try {
    sessions = collectSessions(home, hit.repoId, now)
  } catch {
    sessions = []
  }
  const { live } = partitionSessions(sessions)
  const target = live[0]
  if (target) {
    if (target.tmux || target.pid) {
      const panes = tmuxPanes()
      const pane = target.tmux || (target.pid ? paneForPid(target.pid, panes) : null)
      if (pane) {
        try {
          const args = process.env.TMUX
            ? ['switch-client', '-t', pane]
            : ['attach-session', '-t', String(pane).split(':')[0]]
          execFileSync('tmux', args, { stdio: 'inherit' })
          return true
        } catch {
          /* fall through */
        }
      }
    }
    const hint = jumpHint(target)
    if (hint) {
      process.stdout.write(`${hint}\n`)
      return true
    }
  }
  process.stdout.write(`# sage board  (${hit.label || hit.repoId})\n`)
  return true
}

// Optional fzf path drill-in over contested merge-brief rows. Prints the
// selected path's why-diverged-style detail block; cancel/missing fzf → false
// so the caller falls through to the plain brief (parse-stable).
const tryMergeFzfDrill = (contested, { fileDetail } = {}) => {
  if (!contested.length) return false
  if (!process.stdout.isTTY || !process.stdin.isTTY) return false
  let fzfPath
  try {
    fzfPath = execFileSync('sh', ['-c', 'command -v fzf'], { encoding: 'utf8' }).trim()
  } catch {
    return false
  }
  if (!fzfPath) return false
  const input = contested.map(fzfPathLine).join('\n')
  let stdout = ''
  try {
    stdout = execFileSync(
      fzfPath,
      ['--height=40%', '--reverse', '--prompt=merge ❯ ', '--delimiter=\t', '--with-nth=1'],
      {
        encoding: 'utf8',
        input,
        stdio: ['pipe', 'pipe', 'inherit'],
      },
    )
  } catch {
    return false
  }
  const line = String(stdout || '').trim()
  if (!line) return false
  const p = line.includes('\t') ? line.split('\t').pop() : ''
  const hit = contested.find((c) => c.path === p) || contested.find((c) => line.includes(c.path))
  if (!hit) return false
  // Drill-in: print the single-path brief block (or caller-supplied detail).
  if (typeof fileDetail === 'function') {
    console.log(fileDetail(hit))
  } else {
    console.log(renderMergeBrief([hit], { repoId: hit.path }))
  }
  return true
}

// Optional fzf jump over live board rows. Zero package deps — shells out to
// `fzf` when present. Returns true if a jump was emitted (caller should exit);
// false → print the plain roster. Non-TTY / missing fzf / cancel → false.
const tryBoardFzfJump = (sessions) => {
  const { live } = partitionSessions(sessions)
  if (!live.length) return false
  let fzfPath
  try {
    fzfPath = execFileSync('sh', ['-c', 'command -v fzf'], { encoding: 'utf8' }).trim()
  } catch {
    return false
  }
  if (!fzfPath) return false
  const input = live.map(fzfLine).join('\n')
  let stdout = ''
  try {
    stdout = execFileSync(
      fzfPath,
      ['--height=40%', '--reverse', '--prompt=board ❯ ', '--delimiter=\t', '--with-nth=1'],
      {
        encoding: 'utf8',
        input,
        stdio: ['pipe', 'pipe', 'inherit'],
      },
    )
  } catch {
    return false // cancel / non-zero
  }
  const line = String(stdout || '').trim()
  if (!line) return false
  const sid = line.includes('\t') ? line.split('\t').pop() : ''
  const s = live.find((x) => x.session_id === sid) || live.find((x) => line.includes(x.session_id))
  if (!s) return false
  // Prefer tmux attach when we have a pane; else print cd/worktree hint (war style).
  if (s.tmux || s.pid) {
    const panes = tmuxPanes()
    const pane = s.tmux || (s.pid ? paneForPid(s.pid, panes) : null)
    if (pane) {
      try {
        const args = process.env.TMUX
          ? ['switch-client', '-t', pane]
          : ['attach-session', '-t', String(pane).split(':')[0]]
        execFileSync('tmux', args, { stdio: 'inherit' })
        return true
      } catch {
        /* fall through to cd hint */
      }
    }
  }
  const hint = jumpHint(s)
  if (hint) {
    // Bypass paint for shell-eval friendly cd lines.
    process.stdout.write(`${hint}\n`)
    return true
  }
  return false
}

// Live board: alt-screen + hidden cursor + SGR mouse tracking. Two clocks —
// paint the spinner fast (100 ms) while re-collecting sessions slowly (1 s), so
// liveness/ctx/age refresh live without 10 Hz fs churn; Ctrl-C restores and
// exits. `render(data, frame)` draws the board; `collect()` re-reads. TTY-only
// (the caller guards). Board has no selection machinery — mouse sequences are
// parsed so they never leak as garbage keys; wheel/click are no-ops here.
const runWatch = ({ collect, render }) => {
  const W = process.stdout
  let i = 0
  let data = collect()
  let mousePending = ''
  W.write('\x1b[?1049h\x1b[?25l\x1b[2J') // enter alt screen, hide cursor, clear ONCE
  W.write(MOUSE_ENABLE) // button tracking + SGR extended coords
  const draw = () => {
    // Incremental repaint (same as the war room): home the cursor, clear each
    // line to EOL as we overwrite it, then clear below — instead of a full
    // \x1b[2J every 100ms, which flashed the whole screen (visible flicker).
    const painted = paint(render(data, SPINNER_FRAMES[i % SPINNER_FRAMES.length]))
    const body = painted.split('\n').map((l) => `${l}\x1b[K`).join('\n')
    W.write(`\x1b[H${body}\x1b[J`)
    i++
  }
  draw()
  const paintTimer = setInterval(draw, SPINNER_INTERVAL_MS) // fast: spinner only
  const dataTimer = setInterval(() => {
    data = collect()
  }, 1000) // slow: re-collect the fs (was every 100 ms frame)
  const stop = () => {
    clearInterval(paintTimer)
    clearInterval(dataTimer)
    if (process.stdin.isTTY) process.stdin.setRawMode(false)
    process.stdin.pause()
    // Disable mouse BEFORE leaving alt-screen so tracking never leaks to the shell.
    W.write(MOUSE_DISABLE + '\x1b[?25h\x1b[?1049l')
    process.exit(0)
  }
  process.on('SIGINT', stop)
  if (process.stdin.isTTY) process.stdin.setRawMode(true)
  process.stdin.resume()
  process.stdin.on('data', (buf) => {
    const { rest, pending } = parseMouseEvents(mousePending + buf.toString('utf8'))
    mousePending = pending
    // Consume mouse; board has no selection — only quit keys matter.
    if (rest === '\x03' || rest === 'q') return stop()
  })
}

// Live war-room: alt-screen + raw-mode keys + a selectable, scrollable body.
// Two clocks — paint fast (spinner), re-collect the fleet slowly (fs). Selection
// ordinal + scroll + showAll live here; rendering is delegated to renderWarRoom.
// Enter jumps to the selected session's live tmux pane (agent-agnostic) or, on a
// miss, tears down and prints `cd <worktree>` for a manual resume.
const runWarWatch = (home, { wide, showAll: showAll0 = false } = {}) => {
  const W = process.stdout
  let frame = 0
  let scroll = 0
  let selOrd = 0
  let face = 'live' // LIVE · CLASH · MEMORY
  let showAll = showAll0
  let mode = 'nav'
  let query = ''
  let workingOnly = false
  let showNested = false // Layer B: fold nested armory children into band rollup
  let showZone = true // path localization — on by default (`z` toggles)
  let confirm = false
  let flash = ''
  let bulkTargets = []
  let deadCache = [] // refreshed with fleet — X uses this (no second collectFleet)
  const heat = []
  let view = { repos: [], totals: {} } // active face's fleet-ish view
  let clashView = { repos: [], totals: {} }
  let clashAll = { repos: [], totals: { paths: 0, repos: 0, sessions: 0 } } // unfiltered counts for tabs
  let memoryMeta = { dead: 0, repos: 0, ghosts: 0 }
  let faceCounts = { live: 0, clash: 0, memory: 0 }
  let model = []
  let lastCols = 0
  let paintTimer
  let dataTimer
  let hotState = new Map() // repoId → last-hot ms, for the LIVE hot-float hysteresis
  let hotCount = 0 // repos currently floated into the HOT group (LIVE face)
  const HOT_LINGER_MS = 4000 // a cooled repo lingers hot this long before dropping
  let rawFleet = { repos: [], totals: {} } // unfiltered — source for deadCache
  const termCols = () => {
    const c = W.columns
    return Number.isFinite(c) && c >= 40 ? c : 80
  }
  const termRows = () => {
    const r = W.rows
    return Number.isFinite(r) && r >= 8 ? r : 24
  }
  const bodyHeight = () => Math.max(1, termRows() - WAR_CHROME)
  const selCount = () => selectableIndices(model).length
  const selIdx = () => selectedModelIndex(model, selOrd)
  const syncScroll = () => {
    const idx = selIdx()
    scroll = idx == null ? 0 : ensureVisible(idx, scroll, bodyHeight(), model.length)
  }
  const rebuildModel = () => {
    lastCols = termCols()
    if (face === 'clash') {
      model = bodyModelClash(clashView, { cols: lastCols })
      return
    }
    const showZoneNow = face === 'live' ? showZone : false
    if (face === 'live') {
      // LIVE: hot group floated on top, quiet remainder below, divider between.
      model = liveModel(view, { hotCount, cols: lastCols, showZone: showZoneNow, wide, showNested })
    } else {
      model = bodyModel(view, { wide, showNested, cols: lastCols, showZone: showZoneNow })
    }
  }
  const applyFaceData = () => {
    // Derive active view from rawFleet + face (pure, no extra FS).
    hotCount = 0 // only the LIVE face floats a hot group
    if (face === 'memory') {
      const mem = filterMemoryFleet(rawFleet)
      view = sortFleet(matchFleet(mem, { query, workingOnly: false }))
      memoryMeta = {
        dead: mem.totals.memory_dead || 0,
        repos: mem.totals.memory_repos || view.repos.length,
        ghosts: mem.totals.memory_ghosts || 0,
      }
      clashView = clashAll
    } else if (face === 'clash') {
      view = { repos: [], totals: rawFleet.totals || {} }
      clashView = buildClash(rawFleet, { query, workingOnly })
    } else {
      // LIVE: stable base order, then float the hot group on top (hysteresis).
      const matched = matchFleet(filterFleet(rawFleet, { showAll }), { query, workingOnly })
      const stable = sortFleet(matched)
      const fl = floatHot(stable.repos, hotState, Date.now(), { lingerMs: HOT_LINGER_MS })
      hotState = fl.hotState
      hotCount = fl.hotCount
      view = { repos: fl.order, totals: stable.totals }
      clashView = clashAll
    }
    rebuildModel()
  }
  const setFace = (next) => {
    if (!FACES.includes(next) || next === face) return
    face = next
    scroll = 0
    selOrd = 0
    query = ''
    flash = ''
    applyFaceData()
    selOrd = moveSelection(selCount(), selOrd, 0)
    syncScroll()
    armDataTimer()
  }
  // The session_id under the cursor right now — the anchor we keep the selection
  // pinned to across a rebuild so a reorder/re-collect never slides the cursor
  // onto a different session.
  const selectedSid = () => model[selIdx()]?.session?.session_id || null
  // Re-derive the view after a filter edit while keeping the cursor on the same
  // session (or clamped if it filtered out).
  const refilter = () => {
    const sid = selectedSid()
    applyFaceData()
    selOrd = reselectBySid(model, sid, selOrd)
    syncScroll()
  }
  const refresh = () => {
    // Skip heavy re-collect while a bulk-confirm is open — keeps y/n snappy.
    if (confirm) return
    const anchorSid = selectedSid() // keep the cursor on this session post-rebuild
    try {
      const fleet = collectFleet(home, Date.now())
      // Judge chrome for header + FLEET panel (live sessions and/or fresh briefs).
      try {
        const jc = summarizeJudgeChrome(home, fleet, { now: Date.now() })
        fleet.totals = {
          ...(fleet.totals || {}),
          judges: jc.judges || fleet.totals?.judges || 0,
          judge_label: jc.label || '',
          judge_grace: jc.grace || false,
        }
      } catch {
        /* panels still work without chrome */
      }
      rawFleet = fleet
      deadCache = collectDead(fleet)
      clashAll = buildClash(fleet, {}) // full clash for tab badges + LIVE hints
      // Reuse the clash count just built — faceCountsFromFleet used to rebuild the
      // whole clash model again (a second full O(fleet) pass) just for this number.
      faceCounts = faceCountsFromFleet(fleet, deadCache.length, clashAll.totals.paths || 0)
      faceCounts.judgeChip = fleet.totals?.judge_label || ''
      applyFaceData()
      heat.push(fleet.totals.working)
      if (heat.length > 30) heat.shift()
      selOrd = reselectBySid(model, anchorSid, selOrd) // stay on the same session
      syncScroll()
    } catch {
      // A repo dir vanishing mid-collect (worktree removed, storage moved) must
      // not kill the cockpit — degrade to the last good frame and try again next
      // tick rather than crash out of alt-screen.
      flash = 'refresh skipped (fs changed)'
    }
  }
  const draw = () => {
    const cols = termCols()
    // Resize: reflow the grid so rows never exceed terminal width (wrap = death).
    if (cols !== lastCols) rebuildModel()
    const clock = new Date().toTimeString().slice(0, 8)
    const panels = facePanelTotals(
      face,
      rawFleet.totals || {},
      face === 'clash' ? clashView.totals || {} : clashAll.totals || {},
      {
        dead: deadCache.length,
        repos: memoryMeta.repos || (face === 'memory' ? view.repos.length : 0),
        ghosts: memoryMeta.ghosts || 0,
      },
    )
    const text = renderWarRoom(view, {
      showAll: face === 'memory' ? true : showAll,
      heatValues: heat,
      scroll,
      rows: termRows(),
      cols,
      wide,
      clock,
      selected: selIdx(),
      mode,
      query,
      workingOnly,
      showNested,
      showZone: face === 'live' ? showZone : false,
      manageLabel: flash || labelOf(model[selIdx()]?.session),
      confirm,
      confirmCount: bulkTargets.length,
      deadCount: deadCache.length,
      face,
      panelTotals: panels,
      headerLine: renderWarHeader(face, clock, cols, faceCounts),
      clashCount: faceCounts.clash || 0,
      model, // paint clock must NOT rebuild bodyModel
      hideColumnHeader: face === 'clash',
    })
    const painted = paint(spinnerizeWar(text, SPINNER_FRAMES[frame % SPINNER_FRAMES.length]))
    const body = painted
      .split('\n')
      .map((l) => `${l}\x1b[K`)
      .join('\n')
    W.write(`\x1b[H${body}\x1b[J`)
    frame++
  }
  // MEMORY / showAll: slower data clock so the UI stays interactive.
  // Data-clock cadence scales with fleet size: a huge fleet does not need a 1 Hz
  // re-collect, and even with the mtime cache the stat pass + model rebuild has a
  // cost worth spacing out. MEMORY / showAll stay on the slow clock.
  const baseInterval = () => {
    const n = rawFleet.totals?.sessions || 0
    if (n > 800) return 2500
    if (n > 300) return 1800
    return 1000
  }
  const armDataTimer = () => {
    if (dataTimer) clearInterval(dataTimer)
    const slow = face === 'memory' || showAll
    dataTimer = setInterval(refresh, slow ? 2500 : baseInterval())
  }
  // Restore the terminal to a sane state. Idempotent + sync-only so it is safe
  // as a last-ditch handler on ANY exit path (SIGTERM/SIGHUP/uncaught throw/exit)
  // — previously only SIGINT + explicit user exits ran it, so a crash or kill
  // left the shell stuck in alt-screen + raw mode + mouse tracking.
  let restored = false
  const teardown = () => {
    if (restored) return
    restored = true
    try { clearInterval(paintTimer) } catch {}
    try { clearInterval(dataTimer) } catch {}
    try { if (process.stdin.isTTY) process.stdin.setRawMode(false) } catch {}
    try { process.stdin.pause() } catch {}
    // Disable mouse BEFORE leaving alt-screen so tracking never leaks to the shell.
    try { W.write(MOUSE_DISABLE + '\x1b[?25h\x1b[?1049l') } catch {}
  }
  const stop = () => {
    teardown()
    process.exit(0)
  }
  const printLocation = (s) => {
    console.log(`cd ${s.worktree}`)
    console.log(`# session ${String(s.session_id || '').slice(0, 8)} (${s.branch || '—'}) — resume in your agent`)
  }
  const enter = () => {
    const idx = selIdx()
    const s = idx == null ? null : model[idx]?.session
    if (!s) return
    const pane = paneForPid(s.pid, tmuxPanes())
    teardown()
    if (pane) {
      try {
        const args = process.env.TMUX
          ? ['switch-client', '-t', pane]
          : ['attach-session', '-t', pane.split(':')[0]]
        execFileSync('tmux', args, { stdio: 'inherit' })
        return process.exit(0)
      } catch {
        // tmux miss → fall through to the cd-print
      }
    }
    printLocation(s)
    process.exit(0)
  }
  const cdPrint = () => {
    const idx = selIdx()
    const s = idx == null ? null : model[idx]?.session
    if (!s) return
    teardown()
    printLocation(s)
    process.exit(0)
  }
  const labelOf = (s) =>
    s
      ? `${s.window_name ? `${s.window_name} · ` : ''}${s.branch || String(s.session_id || '').slice(0, 8) || '—'}`
      : ''
  const killRecord = (s) => {
    try {
      if (s?.repo_id && s?.session_id) fs.rmSync(sessionFile(home, s.repo_id, s.session_id))
    } catch {}
  }
  // X from nav/manage: use the cached dead list (instant). y then deletes.
  const beginClearDead = () => {
    bulkTargets = deadCache.length ? deadCache.slice() : collectDead(rawFleet)
    if (!bulkTargets.length) {
      // One expensive rescan only when the cache is empty.
      const fleet = collectFleet(home, Date.now())
      rawFleet = fleet
      deadCache = collectDead(fleet)
      bulkTargets = deadCache.slice()
    }
    if (!bulkTargets.length) {
      flash = 'no dead'
      return draw()
    }
    confirm = true
    flash = ''
    return draw()
  }
  const commitClearDead = () => {
    const targets = bulkTargets
    const n = targets.length
    bulkTargets = []
    confirm = false
    mode = 'nav'
    for (const s of targets) killRecord(s)
    deadCache = []
    flash = n ? `cleared ${n} dead` : ''
    refresh()
    // Stay on MEMORY so the human sees the graveyard empty out
    if (face !== 'memory') face = 'memory'
    applyFaceData()
    draw()
  }
  W.write('\x1b[?1049h\x1b[?25l\x1b[2J') // enter alt-screen, hide cursor, clear once
  W.write(MOUSE_ENABLE) // button tracking + SGR extended coords
  refresh()
  draw()
  paintTimer = setInterval(draw, SPINNER_INTERVAL_MS)
  armDataTimer()
  process.on('SIGINT', stop)
  process.on('SIGTERM', stop)
  process.on('SIGHUP', stop)
  process.on('exit', teardown) // last-ditch sync restore on any exit path
  process.on('uncaughtException', (e) => {
    teardown()
    console.error(e)
    process.exit(1)
  })
  process.on('SIGWINCH', () => {
    rebuildModel()
    syncScroll()
    draw()
  })
  if (process.stdin.isTTY) process.stdin.setRawMode(true)
  process.stdin.resume()
  let mousePending = ''
  // Chrome above the body: header(1)+panels(4)+colHeader(1) = WAR_CHROME - footer(1).
  // SGR y is 1-based; body row 0 sits on screen row (chromeAbove + 1).
  const chromeAboveBody = () => WAR_CHROME - 1
  const applyMouse = (ev) => {
    // Only nav mode moves the selection — same gate as j/k (confirm/help/filter/manage own keys).
    if (mode !== 'nav' || confirm) return
    if (ev.type === 'wheel-up') {
      selOrd = moveSelection(selCount(), selOrd, -1)
      syncScroll()
      return draw()
    }
    if (ev.type === 'wheel-down') {
      selOrd = moveSelection(selCount(), selOrd, 1)
      syncScroll()
      return draw()
    }
    if (ev.type === 'click') {
      const height = bodyHeight()
      const bodyRow = ev.y - 1 - chromeAboveBody() // 0-based within body viewport
      if (bodyRow < 0 || bodyRow >= height) return // chrome / footer / off-screen
      const vp = stickyViewport(model, { scroll, height, selected: selIdx() })
      const entry = vp.rows[bodyRow]
      const mi = entry?.modelIndex
      if (mi == null) return // stuck header / empty
      const ord = selectableIndices(model).indexOf(mi)
      if (ord < 0) return // repo band — not selectable
      selOrd = ord
      syncScroll()
      return draw()
    }
  }
  process.stdin.on('data', (buf) => {
    const parsed = parseMouseEvents(mousePending + buf.toString('utf8'))
    mousePending = parsed.pending
    for (const ev of parsed.events) applyMouse(ev)
    const k = parsed.rest
    if (!k) return // pure mouse chunk or incomplete prefix held as pending
    if (k === '\x03') return stop() // Ctrl-C always quits, even mid-filter
    // Confirm is global — nav X and manage X both land here (y/n/esc).
    if (confirm) {
      if (k === 'y' || k === 'Y') return commitClearDead()
      if (k === 'n' || k === 'N' || k === '\x1b') {
        confirm = false
        bulkTargets = []
        return draw()
      }
      return
    }
    // Help overlay — ? / h toggle; esc / q closes (q only closes help, not war).
    if (mode === 'help') {
      if (k === '?' || k === 'h' || k === 'H' || k === '\x1b' || k === 'q') {
        mode = 'nav'
        return draw()
      }
      return // ignore other keys while reading help
    }
    if (mode === 'filter') {
      if (k === '\x1b') {
        query = ''
        mode = 'nav'
        refilter()
        return draw()
      }
      if (k === '\r' || k === '\n') {
        mode = 'nav'
        return draw()
      }
      if (k === '\x7f' || k === '\b') {
        query = query.slice(0, -1)
        refilter()
        return draw()
      }
      // Accept single keys and multi-char paste bursts (printable only; drop CSI/controls).
      const printable = [...k].filter((ch) => ch >= ' ' && ch !== '\x7f').join('')
      if (printable) {
        query += printable
        refilter()
        return draw()
      }
      return
    }
    if (mode === 'manage') {
      flash = '' // any key clears a transient flash
      if (k === '\x1b') {
        mode = 'nav'
        return draw()
      }
      if (k === 'k') {
        const s = model[selIdx()]?.session
        if (!isKillable(s)) {
          flash = 'live — not killable'
          return draw()
        }
        killRecord(s)
        mode = 'nav'
        refresh()
        return draw()
      }
      if (k === 'X') return beginClearDead()
      return
    }
    if (k === 'q') return stop() // q quits in nav mode only (a filter char otherwise)
    // Full instructions (compact footer only shows a reminder).
    if (k === '?' || k === 'h' || k === 'H') {
      mode = 'help'
      return draw()
    }
    // Faces: ← → / [ ] / 1 2 3  (oracle-shaped; ↑↓ still moves selection)
    if (k === '\x1b[C' || k === ']') {
      setFace(nextFace(face))
      return draw()
    }
    if (k === '\x1b[D' || k === '[') {
      setFace(prevFace(face))
      return draw()
    }
    if (k === '1') {
      setFace('live')
      return draw()
    }
    if (k === '2') {
      setFace('clash')
      return draw()
    }
    if (k === '3') {
      setFace('memory')
      return draw()
    }
    // Graveyard kill — first-class on MEMORY; still available on LIVE with showAll
    if (k === 'X') {
      if (face === 'clash') {
        flash = 'use MEMORY to clear dead'
        return draw()
      }
      return beginClearDead()
    }
    if (k === 'm') {
      if (face === 'clash') {
        flash = 'use MEMORY to manage dead'
        return draw()
      }
      if (selIdx() != null) {
        mode = 'manage'
        flash = ''
        if (face !== 'memory' && !showAll) {
          showAll = true
          armDataTimer()
          refresh()
        } else if (face === 'memory') {
          // already terminal-only
        }
        return draw()
      }
      return
    }
    if (k === '\r' || k === '\n') return enter()
    if (k === 'c') return cdPrint()
    if (k === 'a') {
      if (face !== 'live') {
        flash = 'all is a LIVE lens — try MEMORY'
        return draw()
      }
      showAll = !showAll
      armDataTimer()
      refresh()
      return draw()
    }
    if (k === 'r') {
      refresh()
      return draw()
    }
    if (k === '/') {
      mode = 'filter'
      return draw()
    }
    if (k === 'w') {
      if (face === 'memory') {
        flash = 'working filter is LIVE/CLASH'
        return draw()
      }
      workingOnly = !workingOnly
      applyFaceData()
      selOrd = moveSelection(selCount(), selOrd, 0)
      syncScroll()
      return draw()
    }
    if (k === 'n') {
      if (face === 'clash') {
        flash = 'nested is LIVE/MEMORY'
        return draw()
      }
      showNested = !showNested
      rebuildModel()
      selOrd = moveSelection(selCount(), selOrd, 0)
      syncScroll()
      return draw()
    }
    // Toggle ZONE (path localization) — LIVE only
    if (k === 'z') {
      if (face !== 'live') {
        flash = 'zone is a LIVE column'
        return draw()
      }
      showZone = !showZone
      rebuildModel()
      syncScroll()
      return draw()
    }
    let d = 0
    if (k === '\x1b[A' || k === 'k') d = -1 // up
    else if (k === '\x1b[B' || k === 'j') d = 1 // down
    else if (k === '\x1b[5~') d = -bodyHeight() // pgup
    else if (k === '\x1b[6~') d = bodyHeight() // pgdn
    else return
    selOrd = moveSelection(selCount(), selOrd, d)
    syncScroll()
    draw()
  })
}

const main = async () => {
  const [cmd, a1, a2] = process.argv.slice(2)
  const home = os.homedir()
  const cwd = process.cwd()
  const now = Date.now()

  // Best-effort: stamp this session's "asking" breadcrumb so a statusline can
  // surface it. Only marks a session SAGE is enabled for AND already has a
  // record for — a read verb never fabricates a record.
  const stampAsking = (repoId, verb) => {
    try {
      if (!repoId || !isEnabled({ home, repoId, cwd })) return
      const sid = resolveSelfSid(home, repoId)
      if (sid && !/[/\\]|\.\./.test(sid) && readRecord(home, repoId, sid)) markAsking(home, sid, verb)
    } catch {
      /* best-effort — never let the breadcrumb break a consult */
    }
  }

  const noBrief = process.argv.includes('--no-brief')
  const withBriefs = (factText, repoId) => {
    if (noBrief || !repoId) return factText
    try {
      const now = Date.now()
      const briefs = loadAttachableBriefs(home, repoId, { now, noBrief })
      return attachBriefText(factText, briefs, { now, home })
    } catch {
      return factText
    }
  }
  const briefsEnvelope = (repoId) => {
    if (noBrief || !repoId) return { repo: null, fleet: null }
    try {
      return loadAttachableBriefs(home, repoId, { now: Date.now(), noBrief })
    } catch {
      return { repo: null, fleet: null }
    }
  }

  switch (cmd) {
    case 'board': {
      const repoId = resolveRepoId(cwd)
      const flags = process.argv.slice(3)
      const watch = flags.includes('--watch')
      const wide = flags.includes('--wide') || flags.includes('-w')
      const showAll = flags.includes('--all')
      const json = flags.includes('--json')
      if (json && watch) {
        console.error('sage: --json and --watch are mutually exclusive')
        process.exit(1)
      }
      if (!repoId) {
        if (json) {
          return console.log(JSON.stringify({
            schema: 1,
            kind: 'sage.board',
            generated_at: new Date().toISOString(),
            repo_id: null,
            sessions: [],
          }))
        }
        return console.log("sage: not a git repo — try 'sage war' for the fleet view")
      }
      const { ctx, adapter } = await adapterCtx(home, repoId, cwd)
      // buildSessions: collect + the exact same row/tmux enrichment the human
      // render path performs. Used by both the render path and --json (one
      // read path). Local to case to keep edits inside board case only.
      const buildSessions = () => {
        const sessions = collectSessions(home, repoId, Date.now())
        if (adapter) for (const s of sessions) { const r = rowOf(adapter, ctx, s); if (r) s.row = r.row }
        const panes = tmuxPanes() // best-effort: jumpable pane per live session
        if (panes.length) for (const s of sessions) { if (s.pid) s.tmux = paneForPid(s.pid, panes) }
        return sessions
      }
      if (json) {
        const sessions = buildSessions()
        return console.log(JSON.stringify({
          schema: 1,
          kind: 'sage.board',
          generated_at: new Date().toISOString(),
          repo_id: repoId,
          sessions,
        }))
      }
      // render(sessions, frame): frame == null → static (no spinner). Data
      // collection (buildSessions) is now on a separate 1 Hz clock, so --watch
      // re-reads the fs once per second, not once per 100 ms spinner frame.
      const termCols = () => {
        const c = process.stdout.columns
        return Number.isFinite(c) && c >= 40 ? c : undefined
      }
      const render = (sessions, frame) => {
        const text = renderBoard(sessions, { repoId, wide, all: showAll, cols: termCols() })
        return frame == null ? text : spinnerize(text, sessions, frame)
      }
      // --watch animates, but only on a real TTY; piped/non-TTY → one static frame.
      if (watch) {
        if (!process.stdout.isTTY) return console.log(render(buildSessions(), null))
        return runWatch({ collect: buildSessions, render })
      }
      // Static board. TTY+fzf → optional jump picker over live rows; cancel or
      // missing fzf falls through to the plain roster (parse-stable either way).
      const sessions = buildSessions()
      if (process.stdout.isTTY && process.stdin.isTTY && !showAll) {
        const jumped = tryBoardFzfJump(sessions)
        if (jumped) return
      }
      return console.log(render(sessions, null))
    }
    case 'fleet': {
      const repoId = resolveRepoId(cwd)
      const json = process.argv.slice(3).includes('--json')
      if (!repoId) {
        if (json) {
          return console.log(JSON.stringify({
            schema: 1,
            kind: 'sage.fleet',
            generated_at: new Date().toISOString(),
            repo_id: null,
            self_sid: null,
            sessions: [],
          }))
        }
        return console.log('sage: not a git repo')
      }
      stampAsking(repoId, 'fleet')
      if (json) {
        return console.log(JSON.stringify({
          schema: 1,
          kind: 'sage.fleet',
          generated_at: new Date().toISOString(),
          repo_id: repoId,
          self_sid: resolveSelfSid(home, repoId) || null,
          sessions: collectSessions(home, repoId, now),
          briefs: briefsEnvelope(repoId),
        }))
      }
      const selfSid = resolveSelfSid(home, repoId) || undefined
      const sessions = collectSessions(home, repoId, now)
      // Human HUD: composable chips (live, ⚔, nearest, ctx, asking). fleetLine
      // stays the SessionStart brief + emitter path (byte-stable, untested here).
      const asking =
        selfSid &&
        (() => {
          try {
            return askingAgeMs(home, selfSid, now) < 8000
          } catch {
            return false
          }
        })()
      const hud = fleetHud(sessions, {
        selfSid,
        asking,
        contested: contestedCount(sessions.filter((s) => s.liveness !== 'dead' && s.liveness !== 'closed')),
      })
      const base = hud
        ? `sage: ${hud}`
        : (() => {
            const line = fleetLine(sessions, { selfSid })
            return line ? `sage: ${line}` : 'sage: no other sessions'
          })()
      return console.log(withBriefs(base, repoId))
    }
    case 'territory': {
      const repoId = resolveRepoId(cwd)
      if (!repoId) return console.log('sage: not a git repo (cd into a repo SAGE judges)')
      stampAsking(repoId, 'territory')
      const queries = process.argv.slice(3)
      if (!queries.length) return console.log('usage: sage territory <glob> [glob…]')
      const selfSid = resolveSelfSid(home, repoId) || undefined
      const overlaps = territory(home, repoId, queries, { now, selfSid })
      const { ctx, adapter } = await adapterCtx(home, repoId, cwd)
      if (adapter) for (const o of overlaps) o.zone = zoneOf(adapter, ctx, o.hit)
      return console.log(withBriefs(renderTerritory(overlaps, { queries }), repoId))
    }
    case 'why-diverged': {
      const repoId = resolveRepoId(cwd)
      if (!repoId) return console.log('sage: not a git repo')
      stampAsking(repoId, 'why-diverged')
      if (!a1) return console.log('usage: sage why-diverged <file>')
      const selfSid = resolveSelfSid(home, repoId) || undefined
      const touches = whyDiverged(home, repoId, a1, { now, selfSid })
      // Tier 2 (on demand): real cross-branch numstat for each session that has a
      // live worktree, compared against the first other contesting branch.
      for (const t of touches) {
        const other = touches.find((o) => o.branch && o.branch !== t.branch)
        if (t.worktree && t.branch && other) t.stat = crossStat(t.worktree, other.branch, t.branch, a1)
      }
      const { ctx, adapter } = await adapterCtx(home, repoId, cwd)
      if (adapter) for (const t of touches) t.zone = zoneOf(adapter, ctx, a1)
      return console.log(withBriefs(renderWhyDiverged(touches, { file: a1 }), repoId))
    }
    case 'merge-brief': {
      const repoId = resolveRepoId(cwd)
      if (!repoId) return console.log('sage: not a git repo')
      stampAsking(repoId, 'merge-brief')
      const selfSid = resolveSelfSid(home, repoId) || undefined
      const { ctx, adapter } = await adapterCtx(home, repoId, cwd)
      const extraGlobs = adapter?.generatedGlobs?.() ?? []
      const contested = mergeBrief(home, repoId, { now, selfSid, extraGlobs })
      if (adapter) for (const c of contested) c.zone = zoneOf(adapter, ctx, c.path)
      // TTY+fzf → path drill-in; cancel/missing fzf falls through to full brief.
      if (process.stdout.isTTY && process.stdin.isTTY && contested.length) {
        const drilled = tryMergeFzfDrill(contested, {
          fileDetail: (hit) => renderMergeBrief([hit], { repoId }),
        })
        if (drilled) return
      }
      return console.log(withBriefs(renderMergeBrief(contested, { repoId }), repoId))
    }
    case 'repos': {
      const showAll = process.argv.slice(3).includes('--all')
      const fleet = collectFleet(home, now)
      const view = buildReposView(fleet, { now })
      if (!view.product.length && !view.orphan.length) return console.log('sage: no judged repos yet')
      // TTY+fzf → pick a product repo and jump (board-style); cancel → atlas.
      if (process.stdout.isTTY && process.stdin.isTTY) {
        const jumped = tryReposFzfJump(home, view, { all: showAll, now })
        if (jumped) return
      }
      return console.log(renderRepos(view, { all: showAll }))
    }
    case 'war': {
      const flags = process.argv.slice(3)
      const json = flags.includes('--json')
      const showAll = flags.includes('--all')
      const wide = flags.includes('--wide') || flags.includes('-w')
      const fleet = collectFleet(home, now)
      try {
        const jc = summarizeJudgeChrome(home, fleet, { now })
        fleet.totals = {
          ...(fleet.totals || {}),
          judges: jc.judges || fleet.totals?.judges || 0,
          judge_label: jc.label || '',
          judge_grace: jc.grace || false,
        }
      } catch {
        /* ignore */
      }
      if (json) {
        let fleetBrief = null
        try {
          const b = loadAttachableBriefs(home, null, { now: Date.now() })
          fleetBrief = b.fleet
        } catch {
          /* ignore */
        }
        return console.log(
          JSON.stringify({
            schema: 1,
            kind: 'sage.war',
            generated_at: new Date().toISOString(),
            repos: fleet.repos.map((r) => ({ repo_id: r.repoId, sessions: r.sessions })),
            totals: fleet.totals,
            briefs: { fleet: fleetBrief, repo: null },
            judge: {
              label: fleet.totals?.judge_label || '',
              grace: !!fleet.totals?.judge_grace,
            },
          }),
        )
      }
      // TTY → live cockpit; piped/non-TTY → one static frame. `--all` seeds the
      // live loop's showAll (toggleable at runtime with `a`).
      if (process.stdout.isTTY) return runWarWatch(home, { wide, showAll })
      const view = sortFleet(filterFleet(fleet, { showAll }))
      const clock = new Date().toTimeString().slice(0, 8)
      const counts = {
        ...faceCountsFromFleet(fleet, 0, 0),
        judgeChip: fleet.totals?.judge_label || '',
      }
      return console.log(
        renderWarRoom(view, {
          showAll,
          heatValues: [],
          scroll: 0,
          rows: Number.POSITIVE_INFINITY,
          wide,
          clock,
          panelTotals: { ...fleet.totals, _live: true },
          headerLine: renderWarHeader('live', clock, process.stdout.columns || 80, counts),
        }),
      )
    }
    case 'prune': {
      const repoId = resolveRepoId(cwd)
      if (!repoId) return console.log('sage: not a git repo')
      const flags = process.argv.slice(3)
      const dIdx = flags.indexOf('--days')
      const days = dIdx >= 0 ? Number(flags[dIdx + 1]) || 7 : 7
      const yes = flags.includes('--yes')
      const sessions = collectSessions(home, repoId, Date.now())
      const { remove } = planPrune(sessions, { days, now: Date.now() })
      if (!remove.length) return console.log(`sage: nothing to prune (no closed/dead sessions older than ${days}d)`)
      if (!yes) {
        console.log(`sage: would prune ${remove.length} session(s) older than ${days}d:`)
        for (const s of remove) console.log(`  ${s.liveness}  ${(s.session_id || '').slice(0, 8)}  ${s.branch || '-'}`)
        return console.log('sage: re-run with --yes to delete')
      }
      let gone = 0
      for (const s of remove) {
        try { fs.rmSync(sessionFile(home, repoId, s.session_id)); gone++ } catch {}
      }
      return console.log(`sage: pruned ${gone} session(s)`)
    }
    case 'on':
    case 'off':
      setEnabled(home, cmd === 'on')
      return console.log(`SAGE globally ${cmd === 'on' ? 'enabled' : 'disabled'}`)
    case 'link':
    case 'unlink': {
      const repoId = resolveRepoId(cwd)
      if (!repoId) return console.log('sage: not a git repo')
      if (!a1) return console.log(`usage: sage ${cmd} <session_id>${cmd === 'link' ? ' [state]' : ''}`)
      // Same path-safety guard as claim / SAGE_SELF_SID — sid becomes a filename under sessions/.
      if (/[/\\]|\.\./.test(a1)) return console.log('sage: refusing an unsafe session_id')
      cmd === 'link'
        ? linkSession(home, repoId, a1, a2 || 'linked')
        : unlinkSession(home, repoId, a1)
      return console.log(`sage: ${cmd === 'link' ? `linked ${a1} (${a2 || 'linked'})` : `unlinked ${a1}`}`)
    }
    case 'judge': {
      const sub = a1 || 'status'
      const flags = process.argv.slice(3)
      const wantFleet = flags.includes('--fleet')
      const wantRepo = flags.includes('--repo')
      const wantAuto = flags.includes('--auto')
      const takeover = flags.includes('--takeover')
      const printOnly = flags.includes('--print-only')
      const once = flags.includes('--once')
      const hIdx = flags.indexOf('--harness')
      const harnessFlag = hIdx >= 0 ? flags[hIdx + 1] : undefined
      const repoId = resolveRepoId(cwd)

      if (sub === 'run') {
        const cfg = readJudgeConfig(home)
        const forceScope = wantFleet ? 'fleet' : wantRepo ? 'repo' : wantAuto ? 'auto' : cfg.scope || 'auto'
        const scope = resolveJudgeScope(home, cwd, {
          force: forceScope === 'auto' ? undefined : forceScope,
        })
        if (scope === 'repo' && !repoId)
          return console.log('sage: not a git repo (need cwd for --repo scope)')
        // Fleet still needs a repo to hang the session record on when possible.
        const anchorRepo = repoId || resolveRepoId(cwd)
        if (!anchorRepo && scope === 'fleet')
          return console.log(
            'sage: run from a git repo so the judge session can be recorded (fleet brief is still desk-wide)',
          )
        const harness = resolveHarness(cfg, harnessFlag || cfg.harness)
        let sid = resolveSelfSid(home, anchorRepo) || process.env.SAGE_SELF_SID
        if (!sid || !readRecord(home, anchorRepo, sid)) {
          sid = `judge-${randomUUID().slice(0, 8)}`
        }
        if (printOnly) {
          return console.log(
            printOnlyKit({ scope, harness, sid, repoId: anchorRepo }),
          )
        }
        if (harness.missing) {
          console.log(
            `sage: harness "${harness.name}" not found on PATH\n` +
              `  try: sage judge run --harness none\n` +
              `  or:  sage judge run --print-only`,
          )
          process.exit(1)
        }
        if (harness.fallback) {
          console.log(
            'sage: no grok/claude on PATH — using fact-only keeper (--harness none)\n' +
              '  install grok or claude, or set judge.commands in config.json',
          )
        }
        const slot = ensureJudgeSlot(home, scope, anchorRepo, sid, { takeover })
        if (!slot.ok) return console.log(slot.message)

        if (harness.name === 'none' || harness.fallback) {
          console.log(`sage: judge run · scope=${scope} · harness=none · sid=${sid}`)
          seedJudgeSession(home, anchorRepo, sid, cwd, scope)
          await runNoneKeeper(home, scope, anchorRepo, sid, cwd, {
            once,
            seconds: once ? 1 : 3600,
          })
          if (once) {
            /* leave role for grace window */
          }
          return
        }

        const spawned = spawnHarnessJudge(home, {
          scope,
          repoId: anchorRepo,
          sid,
          cwd,
          harness,
          takeover,
        })
        if (!spawned) return
        if (spawned.mode === 'none') {
          await runNoneKeeper(home, scope, anchorRepo, sid, cwd, { once, seconds: once ? 1 : 3600 })
          return
        }
        // Wait for child; parent stays alive so we could re-seed — harness is the agent.
        await new Promise((resolve) => {
          spawned.child.on('exit', (code) => {
            console.log(`sage: judge harness exited (${code ?? '?'}) — brief may stay for grace`)
            resolve()
          })
          spawned.child.on('error', (err) => {
            console.error(`sage: failed to start ${harness.name}: ${err.message}`)
            resolve()
          })
        })
        return
      }

      if (sub === 'on') {
        if (!wantFleet && !wantRepo)
          return console.log('usage: sage judge on --fleet | --repo [--takeover]')
        if (wantFleet && wantRepo)
          return console.log('sage: pick one scope — --fleet or --repo')
        if (!repoId) return console.log('sage: not a git repo (judge session needs a cwd record)')
        const scope = wantFleet ? 'fleet' : 'repo'
        const sid = resolveSelfSid(home, repoId)
        if (!sid)
          return console.log(
            'sage: cannot resolve the current session — run inside an enabled session, or set SAGE_SELF_SID',
          )
        if (/[/\\]|\.\./.test(sid)) return console.log('sage: refusing an unsafe SAGE_SELF_SID')
        if (!readRecord(home, repoId, sid))
          return console.log(`sage: no open record for ${sid} here — start from a live SAGE session`)
        const holder = slotHolder(home, scope, repoId, { now: Date.now() })
        if (holder && holder.judge_sid !== sid) {
          if (!takeover) {
            return console.log(
              `sage: ${scope} judge slot held by ${holder.judge_sid} — re-run with --takeover to steal`,
            )
          }
          markBriefStale(home, scope, scope === 'repo' ? repoId : null)
        }
        const rec = readRecord(home, repoId, sid) || {}
        mergeRecord(home, repoId, sid, {
          role: 'judge',
          judge_scope: scope,
          judge_at: new Date(now).toISOString(),
          updated_at: new Date(now).toISOString(),
        })
        const file = briefPathFor(home, scope, repoId)
        console.log(
          `sage: judge online (${scope}) · sid ${sid}\n` +
            `  brief path: ${file}\n` +
            `  → load sage-judge skill, poll fleet, sage judge publish`,
        )
        return
      }

      if (sub === 'off') {
        if (!repoId) return console.log('sage: not a git repo')
        const sid = resolveSelfSid(home, repoId)
        if (!sid)
          return console.log(
            'sage: cannot resolve the current session — set SAGE_SELF_SID or run inside a live session',
          )
        const rec = readRecord(home, repoId, sid)
        if (!rec) return console.log(`sage: no open record for ${sid}`)
        const scope = rec.judge_scope === 'fleet' ? 'fleet' : rec.role === 'judge' ? 'repo' : null
        // Clear role fields (merge is shallow; empty string ends isJudge checks)
        mergeRecord(home, repoId, sid, {
          role: '',
          judge_scope: '',
          judge_at: '',
          updated_at: new Date(now).toISOString(),
        })
        if (scope) markBriefStale(home, scope, scope === 'repo' ? repoId : null)
        else {
          markBriefStale(home, 'fleet', null)
          markBriefStale(home, 'repo', repoId)
        }
        return console.log(`sage: judge offline · ${sid}`)
      }

      if (sub === 'show') {
        const scope = wantFleet ? 'fleet' : wantRepo ? 'repo' : repoId ? 'repo' : 'fleet'
        if (scope === 'repo' && !repoId) return console.log('sage: not a git repo')
        const file = briefPathFor(home, scope, repoId)
        const b = readBriefFile(file)
        if (!b || !isBriefFresh(b, { now: Date.now(), home }))
          return console.log(`sage: no fresh ${scope} brief`)
        const text = renderBriefLayers(
          scope === 'fleet' ? { fleet: b, repo: null } : { repo: b, fleet: null },
          { now: Date.now(), home },
        )
        return console.log(text || `sage: no fresh ${scope} brief`)
      }

      if (sub === 'publish') {
        if (!repoId) return console.log('sage: not a git repo')
        const sid = resolveSelfSid(home, repoId)
        if (!sid)
          return console.log(
            'sage: cannot resolve the current session — set SAGE_SELF_SID',
          )
        const rec = readRecord(home, repoId, sid)
        if (!rec || rec.role !== 'judge')
          return console.log('sage: this session is not a judge — run sage judge on first')
        const scope = rec.judge_scope === 'fleet' ? 'fleet' : 'repo'
        let raw = ''
        try {
          raw = await readStdinWithDeadline(3000)
        } catch {
          raw = ''
        }
        if (!String(raw || '').trim())
          return console.log('usage: sage judge publish  < brief.json   (stdin)')
        let parsed
        try {
          parsed = JSON.parse(raw)
        } catch {
          console.error('sage: invalid JSON on stdin')
          process.exit(1)
        }
        const brief = normalizeBrief(
          {
            ...parsed,
            scope,
            repo_id: scope === 'repo' ? repoId : null,
            judge_sid: sid,
            judge_repo_id: repoId,
            judge_pid: rec.pid ?? null,
            status: 'active',
            updated_at: new Date().toISOString(),
            ttl_ms: parsed.ttl_ms ?? DEFAULT_TTL_MS,
          },
          { now: Date.now() },
        )
        if (!brief.summary && !brief.analysis) {
          console.error('sage: brief needs summary or analysis')
          process.exit(1)
        }
        const file = briefPathFor(home, scope, repoId)
        writeBriefFile(file, brief)
        return console.log(`sage: published ${scope} brief → ${file}`)
      }

      // status (default)
      {
        const lines = ['SAGE judge status']
        const nowSt = Date.now()
        const labelFresh = (b) => {
          if (!isBriefFresh(b, { now: nowSt, home })) return 'stale/offline'
          if (isBriefInGrace(b, { now: nowSt, home })) return 'FRESH (grace)'
          return 'FRESH'
        }
        const fb = readBriefFile(briefPathFor(home, 'fleet', null))
        if (fb) {
          lines.push(
            `  fleet: ${labelFresh(fb)} · sid ${fb.judge_sid || '—'} · ${fb.updated_at || ''}`,
          )
          if (fb.summary) lines.push(`         ${fb.summary}`)
        } else lines.push('  fleet: (no brief)')
        if (repoId) {
          const rb = readBriefFile(briefPathFor(home, 'repo', repoId))
          if (rb) {
            lines.push(
              `  repo:  ${labelFresh(rb)} · sid ${rb.judge_sid || '—'} · ${rb.updated_at || ''}`,
            )
            if (rb.summary) lines.push(`         ${rb.summary}`)
          } else lines.push('  repo:  (no brief)')
          const self = resolveSelfSid(home, repoId)
          if (self) {
            const r = readRecord(home, repoId, self)
            if (r?.role === 'judge')
              lines.push(`  self:  judge (${r.judge_scope || 'repo'}) · ${self}`)
          }
        } else lines.push('  repo:  (not in a git repo)')
        return console.log(lines.join('\n'))
      }
    }
    case 'claim': {
      const repoId = resolveRepoId(cwd)
      if (!repoId) return console.log('sage: not a git repo')
      const globs = process.argv.slice(3)
      if (!globs.length) return console.log('usage: sage claim <glob> [glob…]')
      const sid = resolveSelfSid(home, repoId)
      if (!sid)
        return console.log(
          'sage: cannot resolve the current session — run inside an enabled session, or set SAGE_SELF_SID',
        )
      if (/[/\\]|\.\./.test(sid)) return console.log('sage: refusing an unsafe SAGE_SELF_SID')
      if (!readRecord(home, repoId, sid))
        return console.log(`sage: no open record for ${sid} here — claim from the session that owns it`)
      {
        const rec = readRecord(home, repoId, sid)
        if (rec?.role === 'judge')
          return console.log('sage: judge sessions do not claim product territory — sage judge off first')
      }
      mergeRecord(home, repoId, sid, {
        claimed_globs: globs,
        link_state: 'linked',
        updated_at: new Date(now).toISOString(),
      })
      try {
        markAsking(home, sid, 'claim') // best-effort breadcrumb — never break the claim
      } catch {
        /* ignore */
      }
      return console.log(`sage: claimed ${globs.join(' ')} on ${sid}`)
    }
    case 'backlog': {
      const repoId = resolveRepoId(cwd)
      if (!repoId) return console.log('sage: not a git repo (cd into a repo SAGE judges)')
      if (a1 === 'claim') {
        const row = (a2 || '').trim()
        // Strict id shape — the SAME shape backlogRows recognizes (letter+digits);
        // rejects spaces, control chars, and any punctuation noise (a guard, since
        // the value is stored + rendered). A1·R-style sub-rows aren't coordinated.
        if (!/^[A-Za-z]\d{1,6}$/.test(row))
          return console.log('usage: sage backlog claim <row>   (e.g. D11)')
        const sid = resolveSelfSid(home, repoId)
        if (!sid)
          return console.log(
            'sage: cannot resolve the current session — run inside an enabled session, or set SAGE_SELF_SID',
          )
        if (/[/\\]|\.\./.test(sid)) return console.log('sage: refusing an unsafe SAGE_SELF_SID')
        if (!readRecord(home, repoId, sid))
          return console.log(`sage: no open record for ${sid} here — claim from the session that owns it`)
        mergeRecord(home, repoId, sid, {
          claimed_row: row,
          link_state: 'linked',
          updated_at: new Date(now).toISOString(),
        })
        try {
          markAsking(home, sid, 'backlog-claim') // best-effort breadcrumb
        } catch {
          /* ignore */
        }
        return console.log(`sage: claimed row ${row} on ${sid}`)
      }
      // read-only board
      stampAsking(repoId, 'backlog')
      const { ctx, adapter } = await adapterCtx(home, repoId, cwd)
      if (!adapter || typeof adapter.backlogRows !== 'function')
        return console.log('sage: no backlog adapter for this repo')
      let rows = []
      try {
        rows = adapter.backlogRows(ctx) || []
      } catch {
        rows = [] // fail-closed-to-empty: a throwing adapter never crashes the CLI
      }
      if (!rows.length) return console.log('sage: no backlog rows found')
      const sessions = collectSessions(home, repoId, now)
      const panes = tmuxPanes()
      for (const s of sessions) {
        if (panes.length && s.pid) s.tmux = paneForPid(s.pid, panes)
        s.resolvedRow = s.claimed_row || rowOf(adapter, ctx, s)?.row || null
      }
      return console.log(renderBacklog(backlogStatus(rows, sessions, now), { repoId }))
    }
    case 'guard': {
      const repoId = resolveRepoId(cwd)
      if (!repoId) return console.log('sage: not a git repo')
      const sub = a1 || 'list'
      if (sub === 'add' || sub === 'rm') {
        if (!a2) return console.log(`usage: sage guard ${sub} <path>`)
        // Normalize to repo-relative (from the git toplevel) so an absolute, a
        // ./-prefixed, or a from-subdirectory path matches the emitter's
        // repo-relative target — otherwise it silently guards nothing.
        const root = resolveRepoRoot(cwd) || cwd
        let p = relForRepo(path.resolve(cwd, a2), root)
        // A bare existing directory guards nothing without /** — expand it.
        if (sub === 'add' && !/[*?]/.test(p)) {
          try {
            if (fs.statSync(path.resolve(cwd, a2)).isDirectory()) p = `${p.replace(/\/$/, '')}/**`
          } catch {
            /* not an existing dir — keep as a literal path */
          }
        }
        sub === 'add' ? addGuardPath(home, repoId, p) : rmGuardPath(home, repoId, p)
        return console.log(`sage: guard ${sub === 'add' ? 'added' : 'removed'} ${p}`)
      }
      if (sub === 'on') {
        setGuardEnabled(home, repoId, true)
        return console.log('sage: guard ARMED — SAGE will now block edits to contested paths here')
      }
      if (sub === 'off') {
        setGuardEnabled(home, repoId, false)
        return console.log('sage: guard disarmed')
      }
      return console.log(renderGuard(readGuard(home, repoId)))
    }
    case 'statusline': {
      // Fail-open: NEVER break the status bar. Resolve session+cwd from flags →
      // stdin JSON (Claude or Grok status payload) → env (CLAUDE_SESSION_ID or
      // GROK_SESSION_ID). Print the configured label only while a consult is fresh
      // AND SAGE is on; otherwise nothing. Grok users: call explicitly or wire
      // via TUI/terminal script using the env.
      try {
        const slArgs = process.argv.slice(3)
        const flag = (n) => {
          const i = slArgs.indexOf(n)
          return i >= 0 ? slArgs[i + 1] : undefined
        }
        let sid = flag('--session')
        let scwd = flag('--cwd')
        if ((!sid || !scwd) && !process.stdin.isTTY) {
          try {
            const p = JSON.parse(await readStdinWithDeadline(300))
            sid = sid || p.session_id
            scwd = scwd || p.cwd
          } catch {
            /* no / garbage stdin — fall through */
          }
        }
        sid = sid || process.env.CLAUDE_SESSION_ID || process.env.GROK_SESSION_ID
        scwd = scwd || cwd
        if (!sid) return
        const repoId = resolveRepoId(scwd)
        if (!isEnabled({ home, repoId, cwd: scwd })) return
        const cfg = readJson(globalConfig(home)) || {}
        const ttlMs = Number.isFinite(cfg.statuslineTtlMs) ? cfg.statuslineTtlMs : 8000
        const label = typeof cfg.statuslineLabel === 'string' ? cfg.statuslineLabel : '⚖️ Asking Sage'
        // Composable HUD: only non-empty chips. Today the sole chip is the
        // asking pulse; empty → print nothing (fail-open, never an empty chip).
        if (askingAgeMs(home, sid, now) < ttlMs) {
          const out = composeHud([label])
          if (out) process.stdout.write(out)
        } else clearAsking(home, sid)
      } catch {
        /* fail-open: print nothing */
      }
      return
    }
    case 'adapter': {
      const root = resolveRepoRoot(cwd)
      if (!root) return console.log('sage: not a git repo (cd into the repo you want an adapter for)')
      if ((a1 || 'init') !== 'init')
        return console.log(
          'usage: sage adapter init   (scaffold .agentic-sage/adapter.mjs from the template)',
        )
      const dest = path.join(root, '.agentic-sage', 'adapter.mjs')
      const rel = path.relative(root, dest)
      if (fs.existsSync(dest)) return console.log(`sage: ${rel} already exists — edit it (won't overwrite)`)
      const tmpl = path.join(path.dirname(fileURLToPath(import.meta.url)), '..', 'adapters', 'template.mjs')
      fs.mkdirSync(path.dirname(dest), { recursive: true })
      fs.copyFileSync(tmpl, dest)
      return console.log(
        `sage: scaffolded ${rel} from the template\n` +
          `  → edit it to teach SAGE your repo's vocabulary (see ADAPTERS.md)\n` +
          `  → it's committable; or symlink it out-of-tree to ~/.claude/agentic-sage/repos/<id>/adapter.mjs`,
      )
    }
    case 'init': {
      const initLib = await import('../lib/init.mjs')
      const { parseInitArgs, runWizard, renderSummary, renderShow } = initLib
      const { wireAll, wireProject } = await import('../lib/wiring.mjs')
      const { explainRepoDataDir, sageHome, migrateStateDir } = await import('../lib/roots.mjs')
      const repoRoot = path.join(path.dirname(fileURLToPath(import.meta.url)), '..')

      let parsed = parseInitArgs(process.argv.slice(3))
      if (parsed.error) return console.log(`sage: ${parsed.error}\n${USAGE}`)

      if (parsed.mode === 'wizard') {
        if (process.stdin.isTTY && process.stdout.isTTY) {
          parsed = await runWizard({ input: process.stdin, output: process.stderr, cwd })
        } else {
          // No decisive flag + no TTY (agents / CI / piped) → safe default: global, OFF.
          parsed = { mode: 'apply', scope: 'global', harness: 'claude', yes: true, enable: false }
        }
      }

      if (parsed.mode === 'show') return console.log(renderShow({ home, cwd, harness: parsed.harness }))

      // Safe state-dir migration (legacy → new agent home). Init/repair-ONLY —
      // never called from a read verb (board/fleet/where/doctor) or the
      // emitter. A plain rename when new is absent; never merges when both
      // exist (prefer new, warn). A no-op prints nothing (the common case).
      const migration = migrateStateDir(home)
      if (migration === 'renamed') {
        console.log(`sage: migrated legacy state dir → ${sageHome(home)}`)
      } else if (migration === 'both-warn') {
        console.log(
          `sage: both ${sageHome(home)} and the legacy dir exist — using ${sageHome(home)} ` +
            `(legacy left untouched; merge manually if you need its contents)`,
        )
      }

      // Worktree refusal (design §12): a linked worktree must never grow its
      // own repo-root storage — redirect the user to the main checkout.
      const isLinkedWorktree = (dir) => {
        const mainRoot = resolveRepoRoot(dir)
        if (!mainRoot) return false
        try {
          const top = fs.realpathSync(
            execFileSync('git', ['-C', dir, 'rev-parse', '--show-toplevel'], {
              encoding: 'utf8',
              stdio: ['ignore', 'pipe', 'ignore'],
            }).trim(),
          )
          return top !== mainRoot
        } catch {
          return false
        }
      }

      if (parsed.mode === 'repair') {
        const mainRoot = resolveRepoRoot(cwd)
        // Only ask explainRepoDataDir when a mainRoot (or repoId) is
        // resolvable — with neither, its built-in-default rule joins a path
        // with an undefined id and throws.
        const info = mainRoot ? explainRepoDataDir({ home, mainRoot }) : null
        if (mainRoot && info.scope === 'project') {
          let result
          try {
            result = wireProject({ home, repoRoot, projectRoot: cwd })
          } catch (e) {
            return console.log(`sage: ${e.message}`)
          }
          console.log(`sage: re-asserted project wiring (${result.mainRoot})`)
          const enabled = isEnabled({
            home,
            repoId: result.repoId,
            cwd: result.mainRoot,
            scope: 'project',
          })
          return console.log(
            renderSummary({ scope: 'project', enabled, dataDir: result.dataDir, home }),
          )
        }
        let result
        try {
          result = wireAll({ home, repoRoot })
        } catch (e) {
          return console.log(`sage: ${e.message}`)
        }
        console.log('sage: re-asserted global wiring')
        return console.log(
          renderSummary({
            scope: 'global',
            enabled: readEnabled(home),
            dataDir: sageHome(home),
            home,
            harness: 'claude',
          }),
        )
      }

      // apply
      if (parsed.scope === 'project') {
        const projectPath = parsed.projectPath || cwd
        const mainRoot = resolveRepoRoot(projectPath)
        if (!mainRoot)
          return console.log('sage: not a git repo (cd into a repo to init project scope)')
        const storage = parsed.storage || 'repo-root'
        if (storage === 'repo-root' && isLinkedWorktree(projectPath))
          return console.log(
            `sage: repo-root storage must be set up from the main checkout: ${mainRoot}`,
          )
        const projHarness = parsed.harness === 'both' ? 'claude' : (parsed.harness || 'claude')
        let result
        try {
          result = wireProject({ home, repoRoot, projectRoot: projectPath, storage, harness: projHarness })
        } catch (e) {
          return console.log(`sage: ${e.message}`)
        }
        // Never auto-enable: project scope defaults isEnabled() to true absent
        // explicit config, so an un-enabled init must write {enabled:false}.
        setRepoEnabled(result.dataDir, !!parsed.enable)
        const enabled = isEnabled({
          home,
          repoId: result.repoId,
          cwd: result.mainRoot,
          scope: 'project',
        })
        return console.log(
          renderSummary({ scope: 'project', enabled, dataDir: result.dataDir, home, harness: projHarness }),
        )
      }

      let result
      try {
        const harnesses = parsed.harness === 'both' ? ['claude', 'grok'] : [parsed.harness || 'claude']
        for (const h of harnesses) {
          result = wireAll({ home, repoRoot, storageRoot: parsed.storage, harness: h })
        }
      } catch (e) {
        return console.log(`sage: ${e.message}`)
      }
      if (parsed.enable) setEnabled(home, true)
      const displayRoot = parsed.storage || sageHome(home)
      return console.log(
        renderSummary({
          scope: 'global',
          enabled: readEnabled(home),
          dataDir: displayRoot,
          home,
          harness: parsed.harness || 'claude',
        }),
      )
    }
    case 'where': {
      const repoId = resolveRepoId(cwd)
      if (!repoId) return console.log('sage: not a git repo (cd into a repo SAGE judges)')
      const mainRoot = resolveRepoRoot(cwd)
      const { explainRepoDataDir } = await import('../lib/roots.mjs')
      const { formatRuleDetail } = await import('../lib/init.mjs')
      const info = explainRepoDataDir({ home, mainRoot, repoId })
      return console.log(
        [
          'sage: this repo',
          `  scope     ${info.scope}`,
          `  storage   ${info.dir}`,
          `  matched   ${formatRuleDetail(info.rule, { home, mainRoot })}`,
        ].join('\n'),
      )
    }
    case 'enable':
    case 'disable': {
      const repoId = resolveRepoId(cwd)
      if (!repoId) return console.log('sage: not a git repo')
      const mainRoot = resolveRepoRoot(cwd)
      const { explainRepoDataDir } = await import('../lib/roots.mjs')
      const info = explainRepoDataDir({ home, mainRoot, repoId })
      setRepoEnabled(info.dir, cmd === 'enable')
      const label = cmd === 'enable' ? 'enabled' : 'disabled'
      const who = path.basename(mainRoot || cwd)
      return console.log(`sage: ${label} for ${who} (scope: ${info.scope})`)
    }
    case 'doctor':
      return console.log(renderDoctor(doctor(home, cwd)))
    default:
      return console.log(USAGE)
  }
}

main().catch((e) => console.log(`sage: ${e && e.message ? e.message : 'error'}`))
